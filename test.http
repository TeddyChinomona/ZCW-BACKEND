Authorization: Bearer {{accessToken}}
Content-Type: {{contentType}}

{
  "username":         "jdoe",
  "first_name":       "John",
  "last_name":        "Doe",
  "zrp_badge_number": "ZRP-005678",
  "password":         "SecurePass123!",
  "role":             "officer"
}

###

